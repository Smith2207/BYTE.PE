# Neon Postgres — crea un proyecto gratis en https://neon.tech
# Usa la connection string con "-pooler" (PgBouncer) que te da Neon por defecto.
DATABASE_URL="postgresql://usuario:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth (Auth.js) — genera un secreto con: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Mercado Pago en modo sandbox/pruebas — crea una cuenta de prueba en
# https://www.mercadopago.com.pe/developers/panel y copia el Access Token
# y la Public Key de la sección "Credenciales de prueba" (no las de producción).
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""

# Autocompletado de DNI/RUC en el checkout — crea cuenta y token gratis en
# https://apiperu.dev. Se usa solo para autocompletar; si falta o falla,
# el checkout sigue funcionando y el usuario completa los datos a mano.
APIPERU_TOKEN=""

# Subida de imágenes de producto (Vercel Blob) — Vercel dashboard →
# Storage → Create Database → Blob, copia el token generado. Sin esto,
# en desarrollo local cae a guardar en disco (public/uploads/), pero en
# producción la subida falla explícitamente en vez de guardar en un
# filesystem efímero que se perdería igual.
BLOB_READ_WRITE_TOKEN=""

# Envío de correos (confirmación de pedido al cliente + aviso al admin) vía
# Gmail SMTP — myaccount.google.com/apppasswords (necesita verificación en
# 2 pasos activada). NO es la contraseña normal de la cuenta. Sin esto,
# el checkout sigue funcionando igual, solo no se envían los correos.
EMAIL_USER=""
EMAIL_APP_PASSWORD=""

# Autenticación de los cron jobs (/api/cron/*) — Vercel manda automáticamente
# "Authorization: Bearer $CRON_SECRET" en las invocaciones programadas.
# Genera un valor con: openssl rand -base64 32
# Sin esto en producción, esos endpoints devuelven 401. En desarrollo local
# no hace falta: se permiten sin header para poder probar con curl.
CRON_SECRET=""
